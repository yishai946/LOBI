{
  "info": {
    "name": "LOBI API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "origin", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "managerToken", "value": "" },
    { "key": "residentToken", "value": "" },
    { "key": "buildingId", "value": "" },
    { "key": "apartmentId", "value": "" },
    { "key": "issueId", "value": "" },
    { "key": "assignmentId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/request-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "request-otp"] },
            "body": { "mode": "raw", "raw": "{\"phone\":\"05XXXXXXXX\"}" }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify-otp"] },
            "body": { "mode": "raw", "raw": "{\"phone\":\"05XXXXXXXX\",\"otp\":\"123456\"}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] }
          }
        },
        {
          "name": "Complete Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/complete-profile", "host": ["{{baseUrl}}"], "path": ["api", "auth", "complete-profile"] },
            "body": { "mode": "raw", "raw": "{\"name\":\"Test User\"}" }
          }
        },
        {
          "name": "Select Context",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/select-context", "host": ["{{baseUrl}}"], "path": ["api", "auth", "select-context"] },
            "body": {
              "mode": "raw",
              "raw": "{\"type\":\"MANAGER\",\"buildingId\":\"{{buildingId}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create Resident",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{managerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/user/resident", "host": ["{{baseUrl}}"], "path": ["api", "user", "resident"] },
            "body": { "mode": "raw", "raw": "{\"phone\":\"05YYYYYYYY\",\"apartmentId\":\"{{apartmentId}}\"}" }
          }
        },
        {
          "name": "Create Manager",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/user/manager", "host": ["{{baseUrl}}"], "path": ["api", "user", "manager"] },
            "body": { "mode": "raw", "raw": "{\"phone\":\"05XXXXXXXX\",\"buildingId\":\"{{buildingId}}\"}" }
          }
        }
      ]
    },
    {
      "name": "Buildings",
      "item": [
        {
          "name": "Create Building",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/building", "host": ["{{baseUrl}}"], "path": ["api", "building"] },
            "body": { "mode": "raw", "raw": "{\"name\":\"Test Building\",\"address\":\"Somewhere 1\"}" }
          }
        },
        {
          "name": "Get All Buildings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/building", "host": ["{{baseUrl}}"], "path": ["api", "building"] }
          }
        },
        {
          "name": "Get Building By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/building/{{buildingId}}", "host": ["{{baseUrl}}"], "path": ["api", "building", "{{buildingId}}"] }
          }
        }
      ]
    },
    {
      "name": "Apartments",
      "item": [
        {
          "name": "Create Apartment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{managerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/apartment", "host": ["{{baseUrl}}"], "path": ["api", "apartment"] },
            "body": { "mode": "raw", "raw": "{\"name\":\"Apt 1\",\"buildingId\":\"{{buildingId}}\"}" }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment (Manager)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{managerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payments", "host": ["{{baseUrl}}"], "path": ["api", "payments"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"March\",\"description\":\"Maintenance\",\"amount\":120,\"buildingId\":\"{{buildingId}}\",\"isRecurring\":true}"
            }
          }
        },
        {
          "name": "Get Payments (Manager)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/payments", "host": ["{{baseUrl}}"], "path": ["api", "payments"] }
          }
        },
        {
          "name": "Get My Payments (Resident)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{residentToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/payments/my", "host": ["{{baseUrl}}"], "path": ["api", "payments", "my"] }
          }
        },
        {
          "name": "Create Checkout Session (Resident)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{residentToken}}" },
              { "key": "Origin", "value": "{{origin}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/{{assignmentId}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "{{assignmentId}}", "checkout"]
            },
            "body": { "mode": "raw", "raw": "{\"isRecurring\":true}" }
          }
        },
        {
          "name": "Stripe Webhook (Manual)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Stripe-Signature", "value": "t=12345,v1=signature" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payments/webhook", "host": ["{{baseUrl}}"], "path": ["api", "payments", "webhook"] },
            "body": { "mode": "raw", "raw": "{\"type\":\"checkout.session.completed\",\"data\":{\"object\":{\"id\":\"cs_test_123\",\"metadata\":{\"userId\":\"user_1\"}}}}"
            }
          }
        }
      ]
    },
    {
      "name": "Issues",
      "item": [
        {
          "name": "Create Issue (Resident)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{residentToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/issues", "host": ["{{baseUrl}}"], "path": ["api", "issues"] },
            "body": {
              "mode": "raw",
              "raw": "{\"location\":\"Lobby\",\"category\":\"Plumbing\",\"description\":\"Leak\",\"images\":[{\"fileName\":\"leak.jpg\",\"contentType\":\"image/jpeg\"}]}"
            }
          }
        },
        {
          "name": "Get My Issues (Resident)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{residentToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/issues/mine", "host": ["{{baseUrl}}"], "path": ["api", "issues", "mine"] }
          }
        },
        {
          "name": "Get Issues (Manager)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/issues", "host": ["{{baseUrl}}"], "path": ["api", "issues"] }
          }
        },
        {
          "name": "Update Issue (Manager)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{managerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/issues/{{issueId}}", "host": ["{{baseUrl}}"], "path": ["api", "issues", "{{issueId}}"] },
            "body": { "mode": "raw", "raw": "{\"status\":\"IN_PROGRESS\",\"adminComment\":\"Scheduled\"}" }
          }
        },
        {
          "name": "Upload URL (Resident - Legacy)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{residentToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/issues/upload-url", "host": ["{{baseUrl}}"], "path": ["api", "issues", "upload-url"] },
            "body": { "mode": "raw", "raw": "{\"issueId\":\"{{issueId}}\",\"fileName\":\"leak.jpg\",\"contentType\":\"image/jpeg\"}" }
          }
        }
      ]
    }
  ]
}
