generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum PaymentStatus {
  PENDING
  PAID
}

enum IssueStatus {
  open
  inProgress
  done
}

enum RecurringCadence {
  MONTHLY
}

enum RecurringSeriesStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum RecurringEnrollmentStatus {
  ACTIVE
  PAUSED
  CANCELED
}

enum WebhookEventStatus {
  PROCESSING
  PROCESSED
  FAILED
}

model Building {
  id        String   @id @default(uuid())
  name      String?
  address   String
  logoUrl   String?
  createdAt DateTime @default(now())

  apartments      Apartment[]
  managers        Manager[]
  messages        Message[]
  issues          Issue[]
  payments        Payment[]
  recurringSeries RecurringPaymentSeries[]
}

model Apartment {
  id         String   @id @default(uuid())
  name       String
  buildingId String
  createdAt  DateTime @default(now())

  building             Building                     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  residents            Resident[]
  paymentAssignments   PaymentAssignment[]
  recurringEnrollments RecurringPaymentEnrollment[]

  @@unique([buildingId, name])
  @@index([buildingId])
}

model User {
  id         String    @id @default(uuid())
  phone      String    @unique
  name       String?
  role       UserRole  @default(USER)
  isActive   Boolean   @default(true)
  otpCode    String?
  otpExpires DateTime?
  createdAt  DateTime  @default(now())

  issues                 Issue[]
  paymentAssignments     PaymentAssignment[]
  recurringSeriesCreated RecurringPaymentSeries[]
  recurringEnrollments   RecurringPaymentEnrollment[]

  manages    Manager[]
  apartments Resident[]
}

model Resident {
  id          String? @unique @default(uuid())
  userId      String
  apartmentId String

  user      User      @relation(fields: [userId], references: [id])
  apartment Apartment @relation(fields: [apartmentId], references: [id])

  @@id([userId, apartmentId])
}

model Manager {
  id         String @id @default(uuid())
  userId     String
  buildingId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([userId, buildingId])
}

model Message {
  id         String   @id @default(uuid())
  buildingId String
  title      String
  content    String
  isUrgent   Boolean  @default(false)
  createdAt  DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
}

model Issue {
  id           String      @id @default(uuid())
  title        String
  description  String?
  isUrgent     Boolean     @default(false)
  status       IssueStatus @default(open)
  openedAt     DateTime    @default(now())
  inProgressAt DateTime?
  doneAt       DateTime?
  createdById  String
  buildingId   String
  createdAt    DateTime    @default(now())

  building  Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  images    IssueImage[]

  @@index([buildingId])
  @@index([createdById])
}

model Payment {
  id                String   @id @default(uuid())
  title             String
  description       String?
  amount            Decimal
  currency          String   @default("ILS")
  dueAt             DateTime @default(now())
  buildingId        String
  isRecurring       Boolean  @default(false)
  recurringSeriesId String?
  createdAt         DateTime @default(now())

  building        Building                @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  assignments     PaymentAssignment[]
  recurringSeries RecurringPaymentSeries? @relation(fields: [recurringSeriesId], references: [id], onDelete: SetNull)

  @@index([buildingId])
  @@index([recurringSeriesId])
}

model PaymentAssignment {
  id              String        @id @default(uuid())
  paymentId       String
  apartmentId     String
  status          PaymentStatus @default(PENDING)
  stripeSessionId String?
  paidAt          DateTime?
  paidById        String?
  createdAt       DateTime      @default(now())

  payment   Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  paidBy    User?     @relation(fields: [paidById], references: [id], onDelete: SetNull)

  @@unique([paymentId, apartmentId])
  @@index([paymentId])
  @@index([apartmentId])
  @@index([stripeSessionId])
}

model RecurringPaymentSeries {
  id          String                @id @default(uuid())
  buildingId  String
  createdById String
  title       String
  description String?
  amount      Decimal
  currency    String                @default("ILS")
  cadence     RecurringCadence      @default(MONTHLY)
  anchorDay   Int
  startsAt    DateTime              @default(now())
  endsAt      DateTime?
  status      RecurringSeriesStatus @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  building    Building                     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdBy   User                         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  enrollments RecurringPaymentEnrollment[]
  payments    Payment[]

  @@index([buildingId])
  @@index([status])
}

model RecurringPaymentEnrollment {
  id                     String                    @id @default(uuid())
  seriesId               String
  apartmentId            String
  residentId             String?
  providerCustomerId     String?
  providerSubscriptionId String?
  status                 RecurringEnrollmentStatus @default(CANCELED)
  autoPayEnabledAt       DateTime?
  nextBillingAt          DateTime?
  lastChargedAt          DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  series    RecurringPaymentSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  apartment Apartment              @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  resident  User?                  @relation(fields: [residentId], references: [id], onDelete: SetNull)

  @@unique([seriesId, apartmentId])
  @@index([apartmentId])
  @@index([status])
}

model PaymentWebhookEvent {
  id           String             @id @default(uuid())
  provider     String
  eventId      String
  eventType    String
  payloadHash  String?
  deliveryCount Int               @default(1)
  status       WebhookEventStatus @default(PROCESSING)
  receivedAt   DateTime           @default(now())
  lastSeenAt   DateTime           @default(now())
  processedAt  DateTime?
  errorMessage String?

  @@unique([provider, eventId])
  @@index([status])
}

model IssueImage {
  id        String   @id @default(uuid())
  issueId   String
  imageKey  String
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model WebhookReconciliationAttempt {
  id              String   @id @default(uuid())
  webhookEventId  String
  provider        String
  eventId         String
  attemptNumber   Int
  status          String   @default("PENDING")
  errorMessage    String?
  nextAttemptAt   DateTime?
  attemptedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([provider, eventId, attemptNumber])
  @@index([webhookEventId])
  @@index([status])
  @@index([nextAttemptAt])
}

model WebhookMetrics {
  id                   String   @id @default(uuid())
  date                 DateTime @db.Date
  provider             String
  eventType            String
  totalReceived        Int      @default(0)
  totalSucceeded       Int      @default(0)
  totalFailed          Int      @default(0)
  totalReconciled      Int      @default(0)
  avgProcessingTimeMs  Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([date, provider, eventType])
  @@index([date])
  @@index([provider])
}
