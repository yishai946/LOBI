generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum PaymentStatus {
  PENDING
  PAID
}

model Building {
  id           String     @id @default(uuid())
  name         String?
  address      String
  logoUrl      String?
  createdAt    DateTime   @default(now())

  apartments   Apartment[]
  managers Manager[]
  messages     Message[]
  issues       Issue[]
  payments     Payment[]
}

model Apartment {
  id         String    @id @default(uuid())
  name     String
  buildingId String
  createdAt  DateTime  @default(now())

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  payments   Payment[]
  residents Resident[]

  @@index([buildingId])
}

model User {
  id          String    @id @default(uuid())
  phone       String    @unique
  name        String?
  role        UserRole  @default(USER)
  isActive    Boolean   @default(true)
  otpCode     String?
  otpExpires  DateTime?
  createdAt   DateTime  @default(now())

  issues      Issue[]

  manages Manager[]
  apartments Resident[]
}

model Resident {
  userId      String
  apartmentId String

  user        User @relation(fields: [userId], references: [id])
  apartment   Apartment @relation(fields: [apartmentId], references: [id])

  @@id([userId, apartmentId])
}

model Manager {
  id         String    @id @default(uuid())
  userId     String    
  buildingId String

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  building   Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([userId, buildingId])
}

model Message {
  id         String    @id @default(uuid())
  buildingId String
  title      String
  content    String
  isUrgent   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  building   Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
}

model Issue {
  id           String      @id @default(uuid())
  buildingId   String
  createdById  String
  location     String
  category     String
  description  String
  imageUrl     String?
  status       IssueStatus @default(OPEN)
  adminComment String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  building     Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdBy    User        @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@index([createdById])
}

model Payment {
  id          String        @id @default(uuid())
  buildingId  String
  apartmentId String
  month       String        // YYYY-MM
  amount      Decimal
  status      PaymentStatus @default(PENDING)
  receiptUrl  String?
  createdAt   DateTime      @default(now())

  building    Building      @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  apartment   Apartment     @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@index([apartmentId])
  @@unique([apartmentId, month])
}
