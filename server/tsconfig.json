{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "outDir": "./dist",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "types": ["node", "jest"]
  },
  "include": [
    "./server.ts",
    "./src/**/*.ts",
    "./src/types/**/*.d.ts",
    "./prisma/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
